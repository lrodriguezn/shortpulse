# ShortPulse environment configuration
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Required -------------------------------------------------------------

# PostgreSQL connection string. Used by Drizzle migrations and the API.
DATABASE_URL=postgres://shortpulse:shortpulse@localhost:5432/shortpulse

# Port the Fastify server binds to. Frontend (Vite dev) defaults to 5173.
PORT=3000

# Public base URL used to render short links, e.g. http://localhost:3000
BASE_URL=http://localhost:3000

# --- Optional -------------------------------------------------------------

# Path to a MaxMind GeoLite2-City.mmdb file on disk. When unset (or the file
# is missing) the app falls back to DummyGeolocator and analytics get
# country=null, city=null. Used in Phase 5 (backend infrastructure).
# GEOIP_DB_PATH=/var/lib/shortpulse/GeoLite2-City.mmdb
