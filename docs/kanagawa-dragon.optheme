    "fg": { "type": "color", "value": "#c5c9c5" },
    "fg-dim": { "type": "color", "value": "#a6a69c" },
    "fg-muted": { "type": "color", "value": "#737c73" },
    "accent": { "type": "color", "value": "#658594" },
    "accent-hover": { "type": "color", "value": "#8BA4B0" },
    "accent-subtle": { "type": "color", "value": "#223249" },
    "success": { "type": "color", "value": "#87a987" },
    "warning": { "type": "color", "value": "#c4b28a" },
    "error": { "type": "color", "value": "#c4746e" },
    "error-subtle": { "type": "color", "value": "#43242B" }
  },
  "themes": {
    "Color Scheme": {
      "Dark (Dragon)": {
        "bg": "#181616",
        "bg-dim": "#12120f",
        "bg-m1": "#1D1C19",
        "bg-surface": "#282727",
        "bg-surface-hover": "#393836",
        "border": "#393836",
        "border-subtle": "#282727",
        "fg": "#c5c9c5",
        "fg-dim": "#a6a69c",
        "fg-muted": "#737c73",
        "accent": "#658594",
        "accent-hover": "#8BA4B0",
        "accent-subtle": "#223249",
        "success": "#87a987",
        "warning": "#c4b28a",
        "error": "#c4746e",
        "error-subtle": "#43242B"
      },
      "Light (Lotus)": {
        "bg": "#e7dba0",
        "bg-dim": "#dcd5ac",
