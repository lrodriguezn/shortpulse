{
  "name": "Kanagawa Dragon - ShortPulse",
  "version": "1.0.0",
  "description": "Kanagawa Dragon (dark) + Kanagawa Lotus (light) theme for ShortPulse",
  "source": "https://github.com/rebelot/kanagawa.nvim",
  "variables": {
    "bg": { "type": "color", "value": "#181616" },
    "bg-dim": { "type": "color", "value": "#12120f" },
    "bg-m1": { "type": "color", "value": "#1D1C19" },
