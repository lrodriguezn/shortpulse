        "border-subtle": "#e5ddb0",
        "fg": "#545464",
        "fg-dim": "#716e61",
        "fg-muted": "#8a8980",
        "accent": "#4d699b",
        "accent-hover": "#5d57a3",
        "accent-subtle": "#c7d7e0",
        "success": "#6f894e",
        "warning": "#cc6d00",
        "error": "#c84053",
        "error-subtle": "#d9a594"
      }
